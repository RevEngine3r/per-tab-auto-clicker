{
  "manifest_version": 3,
  "name": "Per-Tab Auto Clicker",
  "description": "Per-tab auto click scheduler Chrome extension (MV3) with popup, service worker, and content script.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Per-Tab Auto Clicker"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
